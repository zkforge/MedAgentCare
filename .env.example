LLM_API_KEY=your-openai-compatible-api-key
LLM_MODEL_NAME="qwen3.6-plus"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Docker Compose local ports.
MEDAGENTCARE_API_PORT=8000
MEDAGENTCARE_FRONTEND_PORT=5173

# Browser-visible API URL used by the Vite frontend.
VITE_API_BASE_URL=http://localhost:8000

# API CORS allowlist for browser requests from the frontend.
MEDAGENTCARE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional Docker-internal storage paths used by compose.yaml.
MEDAGENTCARE_DOCKER_MILVUS_DB_PATH=/data/knowledge/milvus_lite.db
MEDAGENTCARE_DOCKER_MEMORY_DIR=/data/memory
MEDAGENTCARE_DOCKER_SESSIONS_DIR=/data/sessions
MEDAGENTCARE_DOCKER_HF_HOME=/data/model-cache/huggingface
MEDAGENTCARE_DOCKER_SENTENCE_TRANSFORMERS_HOME=/data/model-cache/sentence-transformers
MEDAGENTCARE_DOCKER_TORCH_HOME=/data/model-cache/torch

# Optional: enables cross-session long-term memory.
MEM0_API_KEY=

# Personal health memory. Env enables backend capability; UI requests still
# control whether each consultation reads/writes long-term memory.
MEDAGENTCARE_MEMORY_ENABLED=1
MEDAGENTCARE_MEMORY_BACKEND=local
MEDAGENTCARE_MEMORY_DIR=
MEDAGENTCARE_MEMORY_MAX_SESSIONS=100

# Visible conversation sessions used by the frontend recent-session list.
MEDAGENTCARE_SESSIONS_DIR=
MEDAGENTCARE_SESSION_MAX_SESSIONS=100

# Optional: mount or generate Milvus Lite database outside the package tree.
MEDAGENTCARE_MILVUS_DB_PATH=

# Optional: Hugging Face mirror and local model caches.
# Local Mac demo example:
# HF_ENDPOINT=https://hf-mirror.com
# HF_HOME=/Users/your-name/.cache/huggingface
# SENTENCE_TRANSFORMERS_HOME=/Users/your-name/.cache/sentence-transformers
# TORCH_HOME=/Users/your-name/.cache/torch
#
# Docker/server example:
# HF_HOME=/data/model-cache/huggingface
# SENTENCE_TRANSFORMERS_HOME=/data/model-cache/sentence-transformers
# TORCH_HOME=/data/model-cache/torch
HF_ENDPOINT=
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=
TORCH_HOME=
